# practicket-sentinel 환경변수 (실제 값은 홈서버 .env 에만, git 커밋 금지)

# Sentry read 토큰 (event:read, project:read, org:read)
SENTRY_ADMIN_TOKEN=sntryu_xxxxxxxx

# Claude Code OAuth 토큰 (claude setup-token 으로 발급, Max 구독)
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-xxxxxxxx

# Gmail 앱 비밀번호 (SMTP 발송용, 16자)
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# GitHub 인증은 `gh auth login --with-token` 으로 설정 (env 불필요)
